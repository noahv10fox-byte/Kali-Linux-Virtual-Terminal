    def cmd_cd(self, args: List[str]) -> str:
        """Cambia de directorio"""
        if not args:
            self.vm.filesystem.current_dir = '/root'
            return ''
        
        path = args[0]
        if path == '/':
            self.vm.filesystem.current_dir = '/'
        elif path == '..':
            parts = self.vm.filesystem.current_dir.split('/')
            if len(parts) > 2:
                self.vm.filesystem.current_dir = '/'.join(parts[:-1])
            else:
                self.vm.filesystem.current_dir = '/'
        else:
            if not path.startswith('/'):
                if self.vm.filesystem.current_dir == '/':
                    path = '/' + path
                else:
                    path = self.vm.filesystem.current_dir + '/' + path
            self.vm.filesystem.current_dir = path
        
        return ''
    
