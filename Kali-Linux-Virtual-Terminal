    def get_file_path(self, path: str) -> List[str]:
        """Divide un path en sus componentes"""
        if path.startswith('/'):
            path = path[1:]
        if path.endswith('/'):
            path = path[:-1]
        if path == '':
            return ['']
        return path.split('/')


